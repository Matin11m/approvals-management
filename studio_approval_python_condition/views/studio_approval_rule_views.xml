<odoo>
    <record id="studio_approval_rule_form_view_python_condition" model="ir.ui.view">
        <field name="name">studio.approval.form.python.condition</field>
        <field name="model">studio.approval.rule</field>
        <field name="inherit_id" ref="web_studio.studio_approval_rule_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='domain']" position="after">
                <notebook>
                    <page string="Approver Python">
                        <group col="1">
                            <field name="approver_python_code_guide" widget="text" readonly="1" nolabel="1" class="text-muted"/>
                            <field name="python_code" widget="text" placeholder="result = record.user_id"/>
                        </group>
                    </page>
                    <page string="Notify Python">
                        <group col="1">
                            <field name="notify_python_code_guide" widget="text" readonly="1" nolabel="1" class="text-muted"/>
                            <field name="notify_python_code" widget="text" placeholder="result = record.team_id.member_ids"/>
                        </group>
                    </page>
                </notebook>
            </xpath>
        </field>
    </record>
</odoo>
